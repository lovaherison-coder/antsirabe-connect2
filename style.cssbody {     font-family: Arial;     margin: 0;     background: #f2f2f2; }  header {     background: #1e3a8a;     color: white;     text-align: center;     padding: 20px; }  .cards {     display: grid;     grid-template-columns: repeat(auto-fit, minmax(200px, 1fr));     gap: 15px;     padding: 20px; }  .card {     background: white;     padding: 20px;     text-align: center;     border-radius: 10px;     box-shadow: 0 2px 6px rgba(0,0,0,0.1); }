body {
    font-family: Arial;
    margin: 0;
    background: #f2f2f2;
}

header {
    background: #1e3a8a;
    color: white;
    text-align: center;
    padding: 20px;
}

.cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
    padding: 20px;
}

.card {
    background: white;
    padding: 20px;
    text-align: center;
    border-radius: 10px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
}
